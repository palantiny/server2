# Palantiny Chatbot Server - 환경 변수 예시
# .env.example을 복사하여 .env 파일을 생성하고 값을 설정하세요.

# 데이터베이스 (Docker Compose 사용 시 postgres:5432)
DATABASE_URL=postgresql+asyncpg://palantiny:palantiny_secret@localhost:5432/palantiny_db

# Redis (Docker Compose 사용 시 redis:6379)
REDIS_URL=redis://localhost:6379/0

# OpenAI API (없으면 Mock 모드로 자동 전환)
OPENAI_API_KEY=

# Mock 모드 강제 사용 (true 시 API 키 있어도 Mock)
USE_MOCK_LLM=true

# 앱 설정
APP_ENV=development
LOG_LEVEL=INFO
